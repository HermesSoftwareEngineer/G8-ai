# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# DeepSeek
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Evolution API
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE_NAME=g8-ai
WEBHOOK_URL=https://SEU_DOMINIO_OU_NGROK/webhook/whatsapp

# Flask
FLASK_ENV=development
FLASK_SECRET_KEY=your-very-secret-key-change-in-prod
PORT=5001

# Fuso horário
TZ=America/Fortaleza
REMINDER_INTERVAL_SECONDS=900  # 15 minutos

# LangGraph — conexão direta com Postgres do Supabase (não usa o pooler)
# Encontre em: Supabase Dashboard > Settings > Database > Connection string > URI
SUPABASE_DB_URL=postgresql://postgres.[ref]:[senha]@aws-0-[region].pooler.supabase.com:5432/postgres

# LangSmith — observabilidade das traces do agente (opcional)
LANGSMITH_API_KEY=lsv2_pt_...
LANGCHAIN_PROJECT=g8-ai
LANGCHAIN_TRACING_V2=true
